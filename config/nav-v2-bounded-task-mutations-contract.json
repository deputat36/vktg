{
  "schema_version": 1,
  "status": "repository_only_prototype",
  "production_applied": false,
  "base_contract_path": "supabase/prototypes/nav_v2_bounded_task_contract.sql",
  "mutation_path": "supabase/prototypes/nav_v2_bounded_task_mutations.sql",
  "event_table": "public.nav_deal_task_mutation_events_v2",
  "public_rpcs": [
    "nav_v2_create_bounded_tasks(uuid,jsonb,uuid)",
    "nav_v2_start_bounded_task(uuid,uuid)",
    "nav_v2_complete_bounded_task(uuid,uuid,uuid)",
    "nav_v2_set_bounded_task_active_outcome(uuid,text,text,date,uuid)",
    "nav_v2_propose_bounded_task_terminal_outcome(uuid,text,text,uuid,uuid)",
    "nav_v2_decide_bounded_task_terminal_outcome(uuid,text,uuid)"
  ],
  "create_item_allowlist": ["task_type","assigned_role","assigned_to","sla_days","evidence_kind","priority","subject_kind","subject_reference_id"],
  "batch_limit": 5,
  "subject_kinds": ["deal","document","review","corporate_document","calendar","external_confirmation"],
  "active_outcomes": {
    "waiting_external": ["awaiting_counterparty","awaiting_bank","awaiting_document"],
    "deferred": ["postponed_by_client","route_changed"]
  },
  "terminal_outcomes": {
    "not_applicable": ["no_longer_required","route_changed"],
    "replaced": ["replaced_by_specific_task","duplicate_work_item"],
    "cancelled": ["process_cancelled","route_changed"]
  },
  "role_rules": {
    "create": ["spn","manager","owner","admin"],
    "operate_assigned": ["spn","lawyer","broker","manager"],
    "operate_supervisor": ["manager","owner","admin"],
    "decide_terminal": ["manager","owner","admin"],
    "viewer_denied": true
  },
  "legacy_guards": {
    "generic_add_task_disabled": true,
    "generic_status_rpc_blocks_contract_v2": true,
    "existing_rows_backfilled": false
  },
  "completion_rules": {
    "open_to_in_progress": true,
    "done_requires_reference_evidence": true,
    "done_sets_completed_confirmed": true,
    "waiting_external_and_deferred_remain_active": true,
    "waiting_external_and_deferred_require_review_date": true,
    "terminal_exception_requires_proposal_and_decision": true,
    "replacement_requires_same_deal_task": true
  },
  "separation_guarantees": {
    "deal_readiness_changed": false,
    "risk_gate_changed": false,
    "deal_status_changed": false,
    "documents_created": false,
    "risks_created": false,
    "automatic_backfill": false
  },
  "production_gate": "Separate deployment PR after authenticated E2E, security review and rollback validation."
}