    "long_payment_number"
  ],
  "funding_routes": {
    "cash": {"lawyer": true, "broker_parallel": false},
    "matcap": {"lawyer": true, "broker_parallel": false},
    "certificate": {"lawyer": true, "broker_parallel": false},
    "mortgage": {"lawyer": true, "broker_parallel": true},
    "military_mortgage": {"lawyer": true, "broker_parallel": true},
    "mortgage_plus_matcap": {
      "lawyer": true,
      "broker_parallel": true,
      "broker_scope": "mortgage_consultation_program_approval_only"
    }
  },
  "no_backlog_guarantees": {
    "deal_created": false,
    "tasks_created": false,
    "documents_created": false,
    "risks_created": false,
    "conversion_is_draft_only": true
  },
  "document_source_policy": {
    "persist_url": false,
    "persist_presence_flag_only": true,
    "production_gate": "Owner must approve source domains and retention rules before any document URL is persisted."
  },
  "security_contract": {
    "tables_have_rls_enabled": true,
    "direct_anon_access": false,
    "direct_authenticated_table_access": false,
    "public_function_execute_revoked": true,
    "anon_function_execute_revoked": true,
    "authenticated_execute_explicitly_granted": true,
    "security_definer_requires_auth_uid_and_active_profile": true,
    "private_helpers_not_executable_by_authenticated": true
  },
  "production_gate": "Apply only after isolated authenticated role/mutation E2E for spn, manager, lawyer, broker, viewer, owner/admin; security advisor review; approved document-source retention policy; and explicit rollout review."
}
