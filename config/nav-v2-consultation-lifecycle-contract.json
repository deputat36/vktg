{
  "schema_version": 1,
  "status": "repository_only_prototype",
  "production_applied": false,
  "project_id": "ofewxuqfjhamgerwzull",
  "prototype_path": "supabase/prototypes/nav_v2_consultation_lifecycle.sql",
  "tables": [
    "public.nav_consultations_v2",
    "public.nav_consultation_messages_v2"
  ],
  "statuses": [
    "new",
    "need_info",
    "answered",
    "convert_to_preparation",
    "closed",
    "cancelled"
  ],
  "decision_to_status": {
    "answer": "answered",
    "need_info": "need_info",
    "convert_to_preparation": "convert_to_preparation"
  },
  "requester_roles": ["spn", "manager", "lawyer", "owner", "admin"],
  "forbidden_requester_roles": ["broker", "viewer"],
  "queue_roles": ["lawyer", "manager", "owner", "admin"],
  "decision_roles": ["lawyer", "owner", "admin"],
  "role_rules": {
    "spn": {
      "create": true,
      "view_own": true,
      "clarify_own": true,
      "decide": false
    },
    "manager": {
      "create": true,
      "view_team": true,
      "decide": false
    },
    "lawyer": {
      "create": true,
      "view_unassigned_or_self_assigned": true,
      "decide_unassigned_or_self_assigned": true
    },
    "owner_admin": {
      "create": true,
      "view_all": true,
      "decide": true
    },
    "broker": {
      "create": false,
      "view": false,
      "decide": false
    },
    "viewer": {
      "create": false,
      "view": false,
      "decide": false
    }
  },
  "transition_rules": [
    {"from": null, "action": "create", "to": "new"},
    {"from": "new", "action": "answer", "to": "answered"},
    {"from": "new", "action": "need_info", "to": "need_info"},
    {"from": "new", "action": "convert_to_preparation", "to": "convert_to_preparation"},
    {"from": "need_info", "action": "clarify", "to": "new"},
    {"from": "answered", "action": "close", "to": "closed"},
    {"from": "convert_to_preparation", "action": "close", "to": "closed"},
    {"from": "new", "action": "cancel", "to": "cancelled"},
    {"from": "need_info", "action": "cancel", "to": "cancelled"}
  ],
  "public_rpcs": [
    "nav_v2_create_consultation(jsonb)",
    "nav_v2_get_consultation_queue(integer)",
    "nav_v2_get_consultation(uuid)",
    "nav_v2_decide_consultation(uuid,text,text)",
    "nav_v2_add_consultation_clarification(uuid,text)",
    "nav_v2_close_consultation(uuid,text,text)"
  ],
  "queue_item_keys": [
    "id",
    "reference",
    "status",
    "request_type",
    "representation_model",
    "object_type",
    "stage",
    "funding_sources",
    "circumstances_count",
    "planned_event_date",
    "has_external_documents",
    "requester_name",
    "requester_role",
    "assigned_lawyer_name",
    "message_count",
    "latest_message_at",
    "created_at",
    "updated_at",
    "age_hours",
    "priority_code",
    "actionable_for_lawyer",
    "next_action"
  ],
  "queue_forbidden_keys": [
    "question",
    "body",
    "safe_reference",
    "document_source_url",
    "client_name",
    "seller_name",
    "buyer_name",
    "phone",
    "email",
    "passport",
    "snils",
    "cadastral_number",
    "address",
